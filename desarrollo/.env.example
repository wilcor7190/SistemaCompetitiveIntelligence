# =============================================================================
# Claude API (Anthropic) — REQUIRED for AI insights
# =============================================================================
# Get your API key at: https://console.anthropic.com/settings/keys
# The system works without it (uses stats-based insights), but with it
# you get LLM-generated insights and vision OCR fallback.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# =============================================================================
# Proxy configuration (optional — only if scraping gets blocked)
# =============================================================================
# SCRAPER_API_KEY=your_key_here
# PROXY_PROVIDER=scraperapi

# =============================================================================
# General settings
# =============================================================================
LOG_LEVEL=INFO
HEADLESS=true
SCREENSHOTS=false
